{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "pinDigests": true,
  "timezone": "Europe/Berlin",
  "schedule": ["* 0 * * *"],
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Auto-merge minor, patch and digest updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Proxy (nginx, certbot) is the first line of defense — check on every workflow run (every 6 hours)",
      "matchFileNames": ["proxy/docker-compose.yml"],
      "schedule": ["at any time"]
    },
    {
      "description": "Immich uses custom postgres image with VectorChord extension — wait for official Immich support before upgrading major versions",
      "matchPackageNames": ["immich-app/postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Home Assistant monthly releases (minor in semver) require manual review — breaking changes are common",
      "matchPackageNames": ["homeassistant/home-assistant"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "reviewers": ["Spiev"],
      "labels": ["homeassistant", "needs-review"]
    }
  ]
}
