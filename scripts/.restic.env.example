# Credential File for restic backup encryption, excluded from gitrepo
# cp ./restic.env.example ./restic.env
# chmod 600 ./restic.env

export RESTIC_PASSWORD="very secure password"

# S3 Offsite Backup (optional - remove these four lines to disable)
# Uses Hetzner Object Storage (S3-compatible) as offsite copy via `restic copy`.
# Bucket itself is free; you pay only for storage used.
export AWS_ACCESS_KEY_ID="YOUR_HETZNER_S3_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="YOUR_HETZNER_S3_SECRET_ACCESS_KEY"
export RESTIC_REPOSITORY2="s3:https://fsn1.your-objectstorage.com/YOUR_BUCKET_NAME/restic-repo"
export RESTIC_PASSWORD2="YOUR_S3_REPO_PASSWORD"

