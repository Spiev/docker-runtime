# Backup configuration — all environment-specific settings.
# Excluded from git. Copy from .restic.env.example and set permissions:
#   cp .restic.env.example .restic.env && chmod 600 .restic.env

# System
export HDD_DEVICE="/dev/YOUR_DISK"        # e.g. /dev/sda1
export HDD_MOUNT="/mnt/YOUR_MOUNT_POINT"  # e.g. /mnt/sda1
export DOCKER_BASE="$HOME/docker"

# MQTT
export MQTT_HOST="localhost"
export MQTT_PORT="1883"

# Local HDD repository
export RESTIC_PASSWORD="YOUR_LOCAL_REPO_PASSWORD"
export RESTIC_REPO="${HDD_MOUNT}/restic-repo"

# S3 Offsite Backup (optional — remove these six lines to disable)
# Uses Hetzner Object Storage (S3-compatible) as offsite copy via `restic copy`.
# Bucket itself is free; you pay only for storage used.
# IMPORTANT: Initialize the S3 repo once before first use:
#   source .restic.env && RESTIC_PASSWORD="$RESTIC_PASSWORD_S3" restic -r "$RESTIC_REPOSITORY_S3" init
export AWS_ACCESS_KEY_ID="YOUR_HETZNER_S3_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="YOUR_HETZNER_S3_SECRET_ACCESS_KEY"
export RESTIC_REPOSITORY_S3="s3:https://YOUR_REGION.your-objectstorage.com/YOUR_BUCKET_NAME/restic-repo"  # e.g. s3:https://nbg1.your-objectstorage.com/my-backup-bucket/restic-repo
export RESTIC_PASSWORD_S3="YOUR_S3_REPO_PASSWORD"
export S3_KEEP_WEEKLY=4    # keep 4 weekly snapshots offsite
export S3_KEEP_MONTHLY=12  # keep 12 monthly snapshots offsite

