# =============================================================================
# Command Line Sensoren für Home Assistant
# =============================================================================
# Diese Datei enthält alle command_line-basierten Sensoren.
# Wird in configuration.yaml eingebunden via: command_line: !include command_line.yaml
#
# HINWEIS: Diese Sensoren laufen auf dem Host-System und benötigen
# entsprechende Berechtigungen im Docker Container.
# =============================================================================

# -----------------------------------------------------------------------------
# Raspberry Pi Hardware Monitoring
# -----------------------------------------------------------------------------
- sensor:
    name: Pi5 Fan Speed
    unique_id: pi5_fan_rpm
    scan_interval: 10
    command: 'cat /sys/devices/platform/cooling_fan/hwmon/*/fan1_input'
    unit_of_measurement: "RPM"
    value_template: "{{ value }}"

# -----------------------------------------------------------------------------
# Webserver Monitoring
# -----------------------------------------------------------------------------
# Ist via uptimerobot gelöst, daher hier entfernt

# -----------------------------------------------------------------------------
# DNS Monitoring (Pi-hole auf k3s)
# -----------------------------------------------------------------------------
- sensor:
    name: Pi-hole DNS Latency (IPv4)
    unique_id: pihole_dns_latency_ipv4
    command: "dig @YOUR_PIHOLE_IP heise.de AAAA +time=2 +tries=1 | awk '/Query time/ {print $4}'"
    unit_of_measurement: "ms"
    state_class: measurement
    scan_interval: 30

- sensor:
    name: Pi-hole DNS Latency (IPv6)
    unique_id: pihole_dns_latency_ipv6
    command: "dig @YOUR_PIHOLE_IPV6 heise.de AAAA +time=2 +tries=1 | awk '/Query time/ {print $4}'"
    unit_of_measurement: "ms"
    state_class: measurement
    scan_interval: 30

